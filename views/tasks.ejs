<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Task Manager</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <div class="container">
    <h1>Task Manager</h1>
    <p class="subtitle">Total Tasks: <strong><%= tasks.length %></strong></p>

    <!-- Create Task Form -->
    <section class="card">
      <h2>Create New Task</h2>
      <form action="/ui/tasks" method="POST">
        <div class="form-group">
          <label>Title *</label>
          <input type="text" name="title" placeholder="Task title" required />
        </div>
        <div class="form-group">
          <label>Description</label>
          <textarea name="description" placeholder="Task description (optional)"></textarea>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Status</label>
            <select name="status">
              <option value="pending">Pending</option>
              <option value="in-progress">In Progress</option>
              <option value="completed">Completed</option>
            </select>
          </div>
          <div class="form-group">
            <label>Priority</label>
            <select name="priority">
              <option value="low">Low</option>
              <option value="medium" selected>Medium</option>
              <option value="high">High</option>
            </select>
          </div>
        </div>
        <button type="submit" class="btn btn-primary">Add Task</button>
      </form>
    </section>

    <!-- Task List -->
    <section class="card">
      <h2>All Tasks</h2>
      <% if (tasks.length === 0) { %>
        <p class="empty-msg">No tasks yet. Create one above!</p>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Title</th>
              <th>Description</th>
              <th>Status</th>
              <th>Priority</th>
              <th>Created</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% tasks.forEach(task => { %>
              <tr>
                <td><strong><%= task.title %></strong></td>
                <td><%= task.description || '—' %></td>
                <td>
                  <span class="badge badge-<%= task.status %>"><%= task.status %></span>
                </td>
                <td>
                  <span class="badge badge-priority-<%= task.priority %>"><%= task.priority %></span>
                </td>
                <td><%= new Date(task.createdAt).toLocaleDateString() %></td>
                <td>
                  <button
                    class="btn btn-edit btn-sm"
                    data-id="<%= task._id %>"
                    data-title="<%= task.title %>"
                    data-description="<%= task.description || '' %>"
                    data-status="<%= task.status %>"
                    data-priority="<%= task.priority %>"
                    onclick="openEditModal(this)"
                  >Edit</button>
                  <form action="/ui/tasks/<%= task._id %>/delete" method="POST" style="display:inline">
                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </section>

    <footer>
      <p>Mini Task Manager API &mdash; Node.js + Express + MongoDB + EJS</p>
    </footer>
  </div>

  <!-- Edit Modal -->
  <div id="editModal" class="modal-overlay" onclick="closeEditModal(event)">
    <div class="modal-box">
      <h2>Edit Task</h2>
      <form id="editForm" method="POST">
        <div class="form-group">
          <label>Title *</label>
          <input type="text" id="editTitle" name="title" required />
        </div>
        <div class="form-group">
          <label>Description</label>
          <textarea id="editDescription" name="description"></textarea>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Status</label>
            <select id="editStatus" name="status">
              <option value="pending">Pending</option>
              <option value="in-progress">In Progress</option>
              <option value="completed">Completed</option>
            </select>
          </div>
          <div class="form-group">
            <label>Priority</label>
            <select id="editPriority" name="priority">
              <option value="low">Low</option>
              <option value="medium">Medium</option>
              <option value="high">High</option>
            </select>
          </div>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn" onclick="closeModal()">Cancel</button>
          <button type="submit" class="btn btn-primary">Save Changes</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    function openEditModal(btn) {
      document.getElementById('editForm').action = '/ui/tasks/' + btn.dataset.id + '/edit';
      document.getElementById('editTitle').value = btn.dataset.title;
      document.getElementById('editDescription').value = btn.dataset.description;
      document.getElementById('editStatus').value = btn.dataset.status;
      document.getElementById('editPriority').value = btn.dataset.priority;
      document.getElementById('editModal').classList.add('active');
    }

    function closeModal() {
      document.getElementById('editModal').classList.remove('active');
    }

    function closeEditModal(event) {
      if (event.target === document.getElementById('editModal')) closeModal();
    }
  </script>
</body>
</html>
